{
  "name": "the-20-corridors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:methodology": "tsx scripts/methodology-audit.ts",
    "validate": "npm run typecheck && npm test && npm run guard:ui-imports && npm run release:engine && npm run readiness:phase2 && npm run smoke:ui && npm run closure:phase2 && npm run smoke:visual && npm run closure:phase3 && npm run readiness:export && npm run qa:export-visual && npm run smoke:export && npm run closure:phase4 && npm run privacy:public-link && npm run contract:public-dto && npm run preview:public-link && npm run closure:phase5 && npm run contract:public-storage && npm run adapter:public-storage-memory && npm run flow:public-link-memory && npm run lifecycle:public-link-ui",
    "snapshots:generate": "tsx scripts/generate-result-snapshots.ts",
    "snapshots:verify": "tsx scripts/verify-result-snapshots.ts",
    "release:engine": "tsx scripts/engine-release-gate.ts",
    "readiness:phase2": "tsx scripts/phase2-readiness.ts",
    "guard:ui-imports": "tsx scripts/ui-import-boundary.ts",
    "smoke:ui": "tsx scripts/ui-smoke-contract.ts",
    "closure:phase2": "tsx scripts/phase2-closure-gate.ts",
    "smoke:visual": "tsx scripts/visual-smoke-contract.ts",
    "closure:phase3": "tsx scripts/phase3-closure-gate.ts",
    "readiness:export": "tsx scripts/local-export-readiness.ts",
    "qa:export-visual": "tsx scripts/export-visual-qa.ts",
    "smoke:export": "tsx scripts/export-smoke-contract.ts",
    "closure:phase4": "tsx scripts/phase4-closure-gate.ts",
    "privacy:public-link": "tsx scripts/public-link-privacy.ts",
    "contract:public-dto": "tsx scripts/public-result-dto-contract.ts",
    "preview:public-link": "tsx scripts/public-link-preview-contract.ts",
    "closure:phase5": "tsx scripts/phase5-preview-closure-gate.ts",
    "contract:public-storage": "tsx scripts/public-result-storage-contract.ts",
    "adapter:public-storage-memory": "tsx scripts/in-memory-public-result-storage-contract.ts",
    "flow:public-link-memory": "tsx scripts/local-persistent-link-flow-contract.ts",
    "lifecycle:public-link-ui": "tsx scripts/public-link-lifecycle-ui-contract.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "next": "^16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
